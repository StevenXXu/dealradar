# .env.example — Copy to .env and fill in your API keys

# Jina Reader API (https://jina.ai/reader)
JINA_API_KEY=

# Apify (https://apify.com) — optional fallback
APIFY_API_TOKEN=

# AI Model Providers (at least one required)
GEMINI_API_KEY=
KIMI_API_KEY=
GLM_API_KEY=
OPENAI_API_KEY=

# Notion (https://www.notion.so)
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Email (SMTP or SendGrid)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=
FROM_EMAIL=dealradar@dealradar.ai
TO_EMAIL=steven@inpcapital.com

# SendGrid (for raise alert emails)
SENDGRID_API_KEY=

# SerpAPI (for raise alert corroboration)
SERPAPI_API_KEY=

# Alert email recipient
ALERT_EMAIL=steven@inpcapital.com
