# .env.example — Copy to .env and fill in your API keys

# Redis Configuration (For Celery Task Queue)
REDIS_URL=redis://localhost:6379/0

# Jina Reader API (https://jina.ai/reader)
JINA_API_KEY=

# Apify (https://apify.com) — optional fallback
APIFY_API_TOKEN=

# AI Model Providers (at least one required)
GEMINI_API_KEY=
KIMI_API_KEY=
GLM_API_KEY=
OPENAI_API_KEY=

# Notion (https://www.notion.so)
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Email (SMTP or SendGrid)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=
FROM_EMAIL=dealradar@dealradar.ai
TO_EMAIL=steven@inpcapital.com

# SendGrid (for raise alert emails)
SENDGRID_API_KEY=

# SerpAPI (for raise alert corroboration)
SERPAPI_API_KEY=

# Alert email recipient
ALERT_EMAIL=steven@inpcapital.com

# Email capture (optional second harvester input)
# When EMAIL_USER and EMAIL_PASSWORD are set, HarvesterPipeline polls
# the inbox each run for inbound deal emails (founder cold outreach,
# VC referrals). Leave both blank to disable.
#
# For Gmail Workspace: use an App Password, not the account password.
# EMAIL_PROTOCOL=auto tries POP3 first and falls back to IMAP if POP3
# is administratively disabled (common in Workspace).
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_PROTOCOL=auto
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
POP_HOST=pop.gmail.com
POP_PORT=995
EMAIL_MAX_MESSAGES=200
